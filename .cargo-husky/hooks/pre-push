#!/bin/sh
set -e

# ── Changelog gate ────────────────────────────────────────────────────────────
# Before pushing, confirm that CHANGELOG.md has been updated in the repo root
# and in every sub-folder that ships its own changelog.
#
# If you have done so, re-run with the confirmation flag:
#
#   CHANGELOGS_UPDATED=1 git push ...
#
# ─────────────────────────────────────────────────────────────────────────────
if [ -z "$CHANGELOGS_UPDATED" ]; then
  echo ""
  echo "CHANGELOG GATE"
  echo ""
  echo "  Have you updated CHANGELOG.md in the repo root AND in all"
  echo "  sub-folders that maintain their own changelog?"
  echo ""
  echo "  If yes, re-run your push with the confirmation flag:"
  echo ""
  echo "      CHANGELOGS_UPDATED=1 git push ..."
  echo ""
  exit 1
fi

echo "Pre-push checks starting..."

echo "[1/8] Checking formatting..."
cargo fmt --all -- --check

echo "[2/8] Running Clippy..."
cargo clippy --all-targets -- -D warnings

echo "[3/8] Type checking..."
cargo check --all-targets

echo "[4/8] Building project..."
cargo build --all-targets

echo "[5/8] Running tests..."
CENTY_HOME="$(mktemp -d)" cargo test --all-targets

echo "[6/8] Running dylint lints..."
cargo dylint --all

echo "[7/8] Validating submodule state..."
cargo run -q -p xtask -- is populated synced clean all-up-to-date

echo "[8/8] Running e2e tests..."
cd e2e && pnpm test && cd ..

echo "Pre-push checks passed!"
