#!/bin/sh
set -eu

# ── Changelog gate ────────────────────────────────────────────────────────────
# Before pushing, confirm that CHANGELOG.md has been updated in the repo root
# and in every sub-folder that ships its own changelog.
#
# If you have done so, re-run with the confirmation flag:
#
#   CHANGELOGS_UPDATED=1 git push ...
#
# ─────────────────────────────────────────────────────────────────────────────
if [ -z "$CHANGELOGS_UPDATED" ]; then
  echo ""
  echo "CHANGELOG GATE"
  echo ""
  echo "  Have you updated CHANGELOG.md in the repo root AND in all"
  echo "  sub-folders that maintain their own changelog?"
  echo ""
  echo "  If yes, re-run your push with the confirmation flag:"
  echo ""
  echo "      CHANGELOGS_UPDATED=1 git push ..."
  echo ""
  exit 1
fi

CENTY_HOME_TEST="$(mktemp -d)"
CENTY_HOME_COV="$(mktemp -d)"
trap 'rm -rf "$CENTY_HOME_TEST" "$CENTY_HOME_COV"' EXIT INT TERM

echo "Pre-push checks starting..."

echo "[1/9] Checking formatting..."
cargo fmt --all -- --check

echo "[2/9] Running Clippy..."
cargo clippy --all-targets -- -D warnings

echo "[3/9] Type checking..."
cargo check --all-targets

echo "[4/9] Building project..."
cargo build --all-targets

echo "[5/9] Running tests..."
CENTY_HOME="$CENTY_HOME_TEST" cargo test --all-targets

echo "[6/9] Checking test coverage..."
IGNORE_REGEX="server/handlers|server/trait_impl|server/startup|server/resolve|server/action_builders|server/actions|server/config_to_proto|server/convert_infra|server/proto_to_config|server/validate_config|app\\.rs|cors\\.rs|run/core|run/mod|logging/init|logging/mod|workspace/create|workspace/data|workspace/standalone|user/git|user/sync|common/org_sync|common/git/branch|common/git/git_remote|cleanup/mod|main\\.rs|server/mod\\.rs|crud/move_io|crud/move_issue|crud/org_sync|org_registry/mod|assets/copy|hooks/runner/post_hooks|crud/get_matchers|crud/migrate|hooks/config/pattern|hook_pattern_segment_matching|item/core/metadata|issue/assets/get\\.rs|issue/assets/list\\.rs|issue/assets/list_shared|create/helpers\\.rs|crud/list\\.rs|crud/read\\.rs|crud/update_helpers|link/crud_fns/create\\.rs|link/storage/io|managed_files_catalog|registry/ignore\\.rs|organizations/assignment\\.rs|org_issues/config\\.rs|org_issues/crud_list\\.rs|org_issues/paths|organizations/sync\\.rs|registry/storage\\.rs|tracking/enrich\\.rs|tracking/ops\\.rs|server/structured_error|user/crud/update\\.rs|user_config/loader\\.rs|utils/display_and_temp_dir|utils/mod\\.rs"
CENTY_HOME="$CENTY_HOME_COV" cargo llvm-cov --all-targets --ignore-filename-regex "$IGNORE_REGEX" --fail-under-lines 100

echo "[7/9] Running dylint lints..."
cargo dylint --all

echo "[8/9] Validating submodule state..."
cargo run -q -p xtask -- is populated synced clean all-up-to-date

echo "[9/9] Running e2e tests..."
(cd e2e && pnpm test)

echo "Pre-push checks passed!"
